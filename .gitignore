# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Python cache
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
*.egg

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/

# Type checking / linting caches
.mypy_cache/
.pyre/
.ruff_cache/

# Jupyter Notebook
.ipynb_checkpoints/

# IDE / editors
.vscode/
.idea/
*.swp
*.swo

# Operating system files
.DS_Store
Thumbs.db

# Environment variables
.env
.env.*
!.env.example

# Project outputs
data/output/*
!data/output/.gitkeep

# Logs
*.log

# Temporary files
*.tmp
*.temp